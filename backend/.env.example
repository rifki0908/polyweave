# Xiaomi MiMo Token Plan (default — required for max token consumption)
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_KEY=replace_with_your_token_plan_key
MIMO_MODEL=mimo-v2.5-pro

# Optional fallbacks (any OpenAI-compatible)
# MIMO_BASE_URL=https://api.openai.com/v1
# MIMO_MODEL=gpt-4o-mini

# Tuning
PER_LANG_MAX_TOKENS=8192
SYNTHESIS_MAX_TOKENS=4096
REQUEST_TIMEOUT_SECONDS=240
